# Tom's Command Center -- Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Required: Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: Your Telegram user ID (security -- only responds to you)
TELEGRAM_OWNER_ID=825333001

# Optional: OpenAI API key (for voice transcription via Whisper)
# OPENAI_API_KEY=sk-...
