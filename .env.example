# Tom's Command Center -- Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# === REQUIRED ===

# Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Telegram user ID (security -- only responds to you)
TELEGRAM_OWNER_ID=825333001

# === OPTIONAL: Voice Messages ===

# OpenAI API key (for voice message transcription via Whisper)
OPENAI_API_KEY=sk-...

# === OPTIONAL: Performance Data (Morning Briefings) ===

# Shopify (Admin API)
# Create a private app: Settings > Apps > Develop apps > Create app > Admin API access
SHOPIFY_STORE_URL=deepbluehealth.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...

# Klaviyo
# Get from: Settings > Account > API Keys > Create Private API Key
KLAVIYO_API_KEY=pk_...

# Meta Ads (Facebook/Instagram)
# Get from: Business Settings > System Users > Generate Token
META_ACCESS_TOKEN=EAAxxxxxxx...
META_AD_ACCOUNT_ID=123456789

# Google Ads (coming soon)
# GOOGLE_ADS_DEVELOPER_TOKEN=...

# === OPTIONAL: Task Management ===

# Asana
# Get from: https://app.asana.com/0/developer-console > Personal access tokens
ASANA_ACCESS_TOKEN=1/1234567890:abcdef...
ASANA_PROJECT_ID=1234567890
ASANA_WORKSPACE_ID=1234567890

# === OPTIONAL: Slack Monitoring ===

# Slack Bot Token
# Setup: https://api.slack.com/apps > Create New App > From Scratch
# OAuth & Permissions > Bot Token Scopes > add:
#   channels:history, channels:read, chat:write, users:read
# Install to Workspace > copy Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-...

# Channel IDs to monitor (comma-separated)
# Find IDs: right-click channel > View channel details > scroll to bottom
SLACK_CHANNEL_IDS=C0123456789,C0987654321
